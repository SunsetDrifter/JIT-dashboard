# --- NetBird Management API ---
# Same value the dashboard uses (NETBIRD_MGMT_API_ENDPOINT). Calls hit <endpoint>/api.
NETBIRD_MGMT_API_ENDPOINT=https://api.netbird.io

# Service-user Personal Access Token (admin role). Provide ONE of these.
# Prefer the *_FILE variant with Docker secrets in production.
NETBIRD_SERVICE_TOKEN=
# NETBIRD_SERVICE_TOKEN_FILE=/run/secrets/netbird_service_token

# --- OIDC (same values as the dashboard) ---
AUTH_AUTHORITY=https://your-idp.example.com/
AUTH_AUDIENCE=your-api-audience

# --- Service config ---
JIT_DB_PATH=/data/jit.db
JIT_LISTEN_PORT=8080
JIT_LISTEN_HOST=0.0.0.0
# CSV of browser origins allowed via CORS. Leave empty when same-origin behind Nginx.
JIT_ALLOWED_ORIGINS=
JIT_SWEEP_INTERVAL_SEC=30
# Default pending-Request TTL for new JIT policies (minutes).
JIT_PENDING_TTL_MINUTES=1440
# Name marker/prefix applied to JIT-owned groups & policies (used to hide them in the UI).
JIT_GROUP_MARKER=jit:
JIT_GRANT_RETENTION_DAYS=90
JIT_RECONCILE_ENABLED=true
LOG_LEVEL=info
